// FN Kasir Link — Prisma Schema Draft V1
// Status: DRAFT BASELINE
// This schema is a technical draft generated from V1 business rules.
// Money is represented as BigInt for safety.
// Quantities use Decimal.
// Final implementation must be reviewed before production migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Domain {
  GLOBAL
  WARUNG
  BRILINK
  ABSENSI
  SYSTEM
}

enum UserStatus {
  active
  inactive
}

enum PartnerType {
  supplier
  consignment
  both
}

enum Effect {
  allow
  deny
}

enum DocumentDomain {
  WARUNG
  BRILINK
}

enum Direction {
  in
  out
}

enum TransactionStatus {
  selesai
  dibatalkan
}

enum PaymentCategory {
  cash
  non_cash
}

enum WarungCashAccount {
  kas_laci
  kas_aman
}

enum PurchasePaymentStatus {
  paid_cash
  supplier_debt
}

enum DebtStatus {
  belum_lunas
  lunas_sebagian
  lunas
}

enum ConsignmentPaymentStatus {
  belum_dibayar
  dibayar_sebagian
  dibayar
}

enum SellableItemType {
  normal
  recipe
  bundle
  consignment
}

enum PriceMode {
  manual
  auto_hpp_profit
}

enum StockMovementType {
  purchase
  sale
  composition_sale
  stock_opname
  expired_return
  consignment_in
  consignment_sale
  consignment_return
  reversal
  adjustment
}

enum StockOpnameMode {
  single_product
  table
}

enum StockOpnameStatus {
  draft
  posted
  cancelled
}

enum BankCategory {
  none
  sesama_bri
  antar_bank
}

enum BrilinkAccount {
  cash
  saldo
}

enum TemporaryFundStatus {
  aktif
  dikembalikan
  dibatalkan
}

enum FeeLedgerDirection {
  income
  reversal
}

enum ClosingStatus {
  closed
}

enum AttendanceRecordStatus {
  valid
  belum_checkout
  dikoreksi
  dibatalkan
}

enum AttendancePointStatus {
  valid
  outside_radius
  gps_unavailable
  invalid_qr
  belum_checkout
}

enum AdjustmentStatus {
  selesai
  dibatalkan
}

enum PrintFormat {
  thermal_58
  thermal_80
  a4_pdf
}

// ============================================================
// GLOBAL TABLES
// ============================================================

model User {
  id                  String      @id @default(uuid()) @db.Uuid
  roleId              String      @db.Uuid
  role                Role        @relation(fields: [roleId], references: [id])
  name                String
  username            String      @unique
  phone               String?
  email               String?
  passwordHash        String
  status              UserStatus  @default(active)
  mustChangePassword  Boolean     @default(false)

  lastLoginAt         DateTime?
  createdAt           DateTime    @default(now())
  createdBy           String?     @db.Uuid
  updatedAt           DateTime    @updatedAt
  updatedBy           String?     @db.Uuid
  deletedAt           DateTime?
  deletedBy           String?     @db.Uuid

  permissionOverrides UserPermissionOverride[]
  auditLogs           AuditLog[]
  loginHistory        LoginHistory[]
  deviceHistory       DeviceHistory[]
  attendanceRecords   AttendanceRecord[]

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  createdBy   String?  @db.Uuid
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.Uuid

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id           String   @id @default(uuid()) @db.Uuid
  module       String
  code         String   @unique
  name         String
  description  String?
  isSensitive  Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles        RolePermission[]
  userOverrides UserPermissionOverride[]

  @@index([module])
  @@index([isSensitive])
}

model RolePermission {
  id           String      @id @default(uuid()) @db.Uuid
  roleId       String      @db.Uuid
  permissionId String      @db.Uuid
  allow        Boolean     @default(true)
  createdAt    DateTime    @default(now())
  createdBy    String?     @db.Uuid

  role         Role        @relation(fields: [roleId], references: [id])
  permission   Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserPermissionOverride {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @db.Uuid
  permissionId String      @db.Uuid
  effect       Effect
  reason       String?
  createdAt    DateTime    @default(now())
  createdBy    String?     @db.Uuid
  updatedAt    DateTime    @updatedAt
  updatedBy    String?     @db.Uuid

  user         User        @relation(fields: [userId], references: [id])
  permission   Permission  @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

model Partner {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  address     String?
  notes       String?
  partnerType PartnerType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  createdBy   String?     @db.Uuid
  updatedAt   DateTime    @updatedAt
  updatedBy   String?     @db.Uuid
  deletedAt   DateTime?
  deletedBy   String?     @db.Uuid

  warungPurchases              WarungPurchase[]
  warungSupplierDebts          WarungSupplierDebt[]
  warungConsignmentProducts    WarungConsignmentProduct[]
  warungConsignmentEntries     WarungConsignmentEntry[]
  brilinkConsignmentProducts   BrilinkConsignmentProduct[]
  brilinkConsignmentEntries    BrilinkConsignmentEntry[]

  @@index([name])
  @@index([partnerType])
  @@index([isActive])
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  scope       String
  key         String
  value       Json
  description String?
  isSensitive Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdBy   String?  @db.Uuid
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.Uuid

  @@unique([scope, key])
  @@index([scope])
}

model DocumentSequence {
  id           String         @id @default(uuid()) @db.Uuid
  domain       DocumentDomain
  sequenceDate DateTime       @db.Date
  lastNumber   Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([domain, sequenceDate])
}

model AuditLog {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String?  @db.Uuid
  user               User?    @relation(fields: [userId], references: [id])
  userNameSnapshot   String?
  roleSnapshot       String?
  domain             Domain
  module             String
  action             String
  entityType         String
  entityId           String?  @db.Uuid
  entityNo           String?
  oldValue           Json?
  newValue           Json?
  ipAddress          String?
  deviceInfo         String?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([domain])
  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Attachment {
  id          String   @id @default(uuid()) @db.Uuid
  entityType  String
  entityId    String   @db.Uuid
  fileName    String
  fileType    String
  fileSize    Int
  storagePath String
  uploadedBy  String   @db.Uuid
  uploadedAt  DateTime @default(now())
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  deletedBy   String?  @db.Uuid

  @@index([entityType, entityId])
}

model PrintLog {
  id                    String      @id @default(uuid()) @db.Uuid
  entityType            String
  entityId              String      @db.Uuid
  documentNo            String?
  printFormat           PrintFormat
  printedBy             String      @db.Uuid
  printedByNameSnapshot String?
  printedAt             DateTime    @default(now())
  printCount            Int         @default(1)
  deviceInfo            String?
  ipAddress             String?

  @@index([entityType, entityId])
  @@index([documentNo])
  @@index([printedAt])
}

model LoginHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String?  @db.Uuid
  user          User?    @relation(fields: [userId], references: [id])
  usernameInput String
  status        String
  failureReason String?
  ipAddress     String?
  deviceInfo    String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DeviceHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id])
  deviceHash    String
  deviceInfo    String
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  lastIpAddress String?
  isTrusted     Boolean  @default(false)

  @@unique([userId, deviceHash])
}

// ============================================================
// WARUNG MASTER, STOCK, POS
// ============================================================

model WarungUnit {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  code              String   @unique
  isDecimalAllowed  Boolean  @default(false)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  createdBy         String?  @db.Uuid
  updatedAt         DateTime @updatedAt
  updatedBy         String?  @db.Uuid
  deletedAt         DateTime?
  deletedBy         String?  @db.Uuid

  stockProducts     WarungStockProduct[]
  conversionsFrom   WarungProductUnitConversion[] @relation("ConversionFromUnit")
  conversionsTo     WarungProductUnitConversion[] @relation("ConversionToUnit")
}

model WarungProductCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  createdBy   String?  @db.Uuid
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.Uuid
  deletedAt   DateTime?
  deletedBy   String?  @db.Uuid

  sellableItems WarungSellableItem[]
}

model WarungStockProduct {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  baseUnitId         String   @db.Uuid
  baseUnit           WarungUnit @relation(fields: [baseUnitId], references: [id])
  sku                String?
  barcode            String?
  minStockQty        Decimal  @default(5) @db.Decimal(18, 3)
  currentStockQty    Decimal  @default(0) @db.Decimal(18, 3)
  currentHppAmount   BigInt   @default(0)
  isActive           Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  createdBy          String?  @db.Uuid
  updatedAt          DateTime @updatedAt
  updatedBy          String?  @db.Uuid
  deletedAt          DateTime?
  deletedBy          String?  @db.Uuid

  sellableItems      WarungSellableItem[]
  conversions        WarungProductUnitConversion[]
  componentOf        WarungItemComposition[]
  stockMovements     WarungStockMovement[]
  purchaseItems      WarungPurchaseItem[]

  @@index([name])
  @@index([isActive])
}

model WarungProductUnitConversion {
  id              String   @id @default(uuid()) @db.Uuid
  stockProductId  String   @db.Uuid
  stockProduct    WarungStockProduct @relation(fields: [stockProductId], references: [id])
  fromUnitId      String   @db.Uuid
  fromUnit        WarungUnit @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnitId        String   @db.Uuid
  toUnit          WarungUnit @relation("ConversionToUnit", fields: [toUnitId], references: [id])
  conversionQty   Decimal  @db.Decimal(18, 6)
  versionNo       Int      @default(1)
  effectiveFrom   DateTime @default(now())
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  createdBy       String?  @db.Uuid
  updatedAt       DateTime @updatedAt
  updatedBy       String?  @db.Uuid

  @@index([stockProductId])
  @@index([fromUnitId, toUnitId])
}

model WarungSellableItem {
  id                   String           @id @default(uuid()) @db.Uuid
  itemType             SellableItemType
  stockProductId       String?          @db.Uuid
  stockProduct         WarungStockProduct? @relation(fields: [stockProductId], references: [id])
  consignmentProductId String?          @db.Uuid
  consignmentProduct   WarungConsignmentProduct? @relation(fields: [consignmentProductId], references: [id])
  categoryId           String           @db.Uuid
  category             WarungProductCategory @relation(fields: [categoryId], references: [id])
  name                 String
  sku                  String?
  barcode              String?
  sellingPriceAmount   BigInt
  priceMode            PriceMode        @default(manual)
  targetProfitAmount   BigInt?
  roundingRule         String?
  isFavorite           Boolean          @default(false)
  isActive             Boolean          @default(true)
  sortOrder            Int              @default(0)
  notes                String?
  createdAt            DateTime         @default(now())
  createdBy            String?          @db.Uuid
  updatedAt            DateTime         @updatedAt
  updatedBy            String?          @db.Uuid
  deletedAt            DateTime?
  deletedBy            String?          @db.Uuid

  compositions         WarungItemComposition[]
  saleItems            WarungSaleItem[]

  @@index([name])
  @@index([categoryId])
  @@index([isFavorite])
  @@index([isActive])
}

model WarungItemComposition {
  id                 String   @id @default(uuid()) @db.Uuid
  sellableItemId     String   @db.Uuid
  sellableItem       WarungSellableItem @relation(fields: [sellableItemId], references: [id])
  componentProductId String   @db.Uuid
  componentProduct   WarungStockProduct @relation(fields: [componentProductId], references: [id])
  qty                Decimal  @db.Decimal(18, 3)
  unitId             String   @db.Uuid
  qtyBase            Decimal  @db.Decimal(18, 3)
  baseUnitId         String   @db.Uuid
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  createdBy          String?  @db.Uuid
  updatedAt          DateTime @updatedAt
  updatedBy          String?  @db.Uuid

  @@index([sellableItemId])
  @@index([componentProductId])
}

model WarungPaymentMethod {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  code        String          @unique
  category    PaymentCategory
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  createdBy   String?         @db.Uuid
  updatedAt   DateTime        @updatedAt
  updatedBy   String?         @db.Uuid
  deletedAt   DateTime?
  deletedBy   String?         @db.Uuid

  sales       WarungSale[]
}

model WarungSale {
  id                         String            @id @default(uuid()) @db.Uuid
  documentNo                 String            @unique
  operationalDate            DateTime          @db.Date
  cashierUserId              String            @db.Uuid
  cashierNameSnapshot        String
  cashierRoleSnapshot        String
  paymentMethodId            String            @db.Uuid
  paymentMethod              WarungPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  paymentMethodNameSnapshot  String
  paymentCategorySnapshot    PaymentCategory
  subtotalAmount             BigInt
  itemDiscountAmount         BigInt            @default(0)
  transactionDiscountAmount  BigInt            @default(0)
  totalDiscountAmount        BigInt            @default(0)
  totalAmount                BigInt
  cashReceivedAmount         BigInt?
  changeAmount               BigInt?
  status                     TransactionStatus @default(selesai)
  reversalOfSaleId           String?           @db.Uuid
  reversedBySaleId           String?           @db.Uuid
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledBy                String?           @db.Uuid
  createdAt                  DateTime          @default(now())
  createdBy                  String            @db.Uuid
  updatedAt                  DateTime          @updatedAt

  items                      WarungSaleItem[]
  cashLedgers                WarungCashLedger[]
  nonCashLedgers             WarungNonCashLedger[]
  consignmentSales           WarungConsignmentSale[]

  @@index([operationalDate])
  @@index([cashierUserId])
  @@index([status])
}

model WarungSaleItem {
  id                          String   @id @default(uuid()) @db.Uuid
  saleId                      String   @db.Uuid
  sale                        WarungSale @relation(fields: [saleId], references: [id])
  sellableItemId              String   @db.Uuid
  sellableItem                WarungSellableItem @relation(fields: [sellableItemId], references: [id])
  sellableItemNameSnapshot    String
  itemTypeSnapshot            SellableItemType
  categoryNameSnapshot        String
  qty                         Decimal  @db.Decimal(18, 3)
  unitNameSnapshot            String?
  qtyBase                     Decimal? @db.Decimal(18, 3)
  sellingPriceSnapshot        BigInt
  hppSnapshotAmount           BigInt?
  grossAmount                 BigInt
  discountAmount              BigInt   @default(0)
  netAmount                   BigInt
  profitAmount                BigInt
  compositionSnapshot         Json?
  consignmentPartnerId        String?  @db.Uuid
  consignmentPartnerSnapshot  String?
  consignmentSetorAmount      BigInt?
  createdAt                   DateTime @default(now())

  consignmentSale             WarungConsignmentSale?

  @@index([saleId])
  @@index([sellableItemId])
}

model WarungCashLedger {
  id                   String            @id @default(uuid()) @db.Uuid
  cashAccount           WarungCashAccount
  direction             Direction
  amount                BigInt
  balanceBeforeAmount   BigInt?
  balanceAfterAmount    BigInt?
  sourceType            String
  sourceId              String            @db.Uuid
  documentNo            String
  operationalDate       DateTime          @db.Date
  description           String?
  createdAt             DateTime          @default(now())
  createdBy             String            @db.Uuid

  sale                  WarungSale?       @relation(fields: [sourceId], references: [id], map: "warung_cash_ledger_sale_fkey", onDelete: NoAction, onUpdate: NoAction)

  @@index([cashAccount])
  @@index([operationalDate])
  @@index([sourceType, sourceId])
  @@index([documentNo])
}

model WarungNonCashLedger {
  id                    String   @id @default(uuid()) @db.Uuid
  paymentMethodId        String   @db.Uuid
  paymentMethodSnapshot  String
  direction              Direction
  amount                 BigInt
  sourceType             String
  sourceId               String   @db.Uuid
  documentNo             String
  operationalDate        DateTime @db.Date
  createdAt              DateTime @default(now())
  createdBy              String   @db.Uuid

  sale                   WarungSale? @relation(fields: [sourceId], references: [id], map: "warung_non_cash_ledger_sale_fkey", onDelete: NoAction, onUpdate: NoAction)

  @@index([paymentMethodId])
  @@index([operationalDate])
  @@index([sourceType, sourceId])
}

// NOTE: Due to Prisma relation constraints, polymorphic ledger relations
// above are indicative. Final implementation may remove direct relation
// fields from ledgers and use sourceType/sourceId only.

// ============================================================
// WARUNG PURCHASE, DEBT, EXPENSE
// ============================================================

model WarungPurchase {
  id                         String                @id @default(uuid()) @db.Uuid
  documentNo                 String                @unique
  operationalDate            DateTime              @db.Date
  partnerId                  String?               @db.Uuid
  partner                    Partner?              @relation(fields: [partnerId], references: [id])
  partnerNameSnapshot        String?
  supplierInvoiceNo          String?
  paymentStatus              PurchasePaymentStatus
  cashSource                 WarungCashAccount?
  subtotalAmount             BigInt
  itemDiscountAmount         BigInt                @default(0)
  invoiceDiscountAmount      BigInt                @default(0)
  totalDiscountAmount        BigInt                @default(0)
  totalAmount                BigInt
  notes                      String?
  status                     TransactionStatus     @default(selesai)
  reversalOfPurchaseId       String?               @db.Uuid
  reversedByPurchaseId       String?               @db.Uuid
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledBy                String?               @db.Uuid
  createdAt                  DateTime              @default(now())
  createdBy                  String                @db.Uuid
  createdByNameSnapshot      String
  createdByRoleSnapshot      String

  items                      WarungPurchaseItem[]
  debt                       WarungSupplierDebt?

  @@index([operationalDate])
  @@index([partnerId])
  @@index([status])
}

model WarungPurchaseItem {
  id                           String   @id @default(uuid()) @db.Uuid
  purchaseId                   String   @db.Uuid
  purchase                     WarungPurchase @relation(fields: [purchaseId], references: [id])
  stockProductId               String   @db.Uuid
  stockProduct                 WarungStockProduct @relation(fields: [stockProductId], references: [id])
  productNameSnapshot          String
  qtyInput                     Decimal  @db.Decimal(18, 3)
  unitNameSnapshot             String
  conversionQtySnapshot        Decimal  @db.Decimal(18, 6)
  qtyBase                      Decimal  @db.Decimal(18, 3)
  baseUnitNameSnapshot         String
  unitPriceAmount              BigInt
  grossAmount                  BigInt
  itemDiscountAmount           BigInt   @default(0)
  invoiceDiscountAllocAmount   BigInt   @default(0)
  netAmount                    BigInt
  hppBeforeAmount              BigInt
  purchaseHppAmount            BigInt
  hppAfterAmount               BigInt
  createdAt                    DateTime @default(now())

  @@index([purchaseId])
  @@index([stockProductId])
}

model WarungSupplierDebt {
  id                    String     @id @default(uuid()) @db.Uuid
  purchaseId             String     @unique @db.Uuid
  purchase               WarungPurchase @relation(fields: [purchaseId], references: [id])
  documentNo             String     @unique
  partnerId              String     @db.Uuid
  partner                Partner    @relation(fields: [partnerId], references: [id])
  partnerNameSnapshot    String
  debtAmount             BigInt
  paidAmount             BigInt     @default(0)
  remainingAmount        BigInt
  status                 DebtStatus @default(belum_lunas)
  dueDate                DateTime?  @db.Date
  notes                  String?
  createdAt              DateTime   @default(now())
  createdBy              String     @db.Uuid
  updatedAt              DateTime   @updatedAt
  updatedBy              String?    @db.Uuid

  payments               WarungSupplierDebtPayment[]

  @@index([partnerId])
  @@index([status])
}

model WarungSupplierDebtPayment {
  id                             String            @id @default(uuid()) @db.Uuid
  documentNo                     String            @unique
  supplierDebtId                 String            @db.Uuid
  supplierDebt                   WarungSupplierDebt @relation(fields: [supplierDebtId], references: [id])
  purchaseDocumentNoSnapshot     String
  partnerId                      String            @db.Uuid
  partnerNameSnapshot            String
  paymentAmount                  BigInt
  cashSource                     WarungCashAccount
  remainingBeforeAmount          BigInt
  remainingAfterAmount           BigInt
  status                         TransactionStatus @default(selesai)
  notes                          String?
  reversalOfPaymentId            String?           @db.Uuid
  reversedByPaymentId            String?           @db.Uuid
  cancellationReason             String?
  cancelledAt                    DateTime?
  cancelledBy                    String?           @db.Uuid
  createdAt                      DateTime          @default(now())
  createdBy                      String            @db.Uuid

  @@index([supplierDebtId])
  @@index([documentNo])
}

model WarungExpenseCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  code        String   @unique
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  createdBy   String?  @db.Uuid
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.Uuid
  deletedAt   DateTime?
  deletedBy   String?  @db.Uuid

  expenses    WarungExpense[]
}

model WarungExpense {
  id                         String            @id @default(uuid()) @db.Uuid
  documentNo                 String            @unique
  operationalDate            DateTime          @db.Date
  categoryId                 String            @db.Uuid
  category                   WarungExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryNameSnapshot       String
  amount                     BigInt
  cashSource                 WarungCashAccount
  description                String?
  relatedPurchaseId          String?           @db.Uuid
  status                     TransactionStatus @default(selesai)
  reversalOfExpenseId        String?           @db.Uuid
  reversedByExpenseId        String?           @db.Uuid
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledBy                String?           @db.Uuid
  createdAt                  DateTime          @default(now())
  createdBy                  String            @db.Uuid
  createdByNameSnapshot      String
  createdByRoleSnapshot      String

  @@index([operationalDate])
  @@index([categoryId])
  @@index([status])
}

// ============================================================
// WARUNG CONSIGNMENT, CLOSING, STOCK MOVEMENT
// ============================================================

model WarungConsignmentProduct {
  id                       String   @id @default(uuid()) @db.Uuid
  partnerId                 String   @db.Uuid
  partner                   Partner  @relation(fields: [partnerId], references: [id])
  partnerNameSnapshot       String
  name                      String
  baseUnitId                String   @db.Uuid
  baseUnitNameSnapshot      String
  sku                       String?
  barcode                   String?
  sellingPriceAmount        BigInt
  setorPriceAmount          BigInt
  profitAmount              BigInt
  currentStockQty           Decimal  @default(0) @db.Decimal(18, 3)
