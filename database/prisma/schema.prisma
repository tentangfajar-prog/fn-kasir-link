  ipAddress      String?

  checkinRecords  AttendanceRecord[] @relation("CheckinQrToken")
  checkoutRecords AttendanceRecord[] @relation("CheckoutQrToken")

  @@index([validUntil])
}

model AttendanceRecord {
  id                         String                @id @default(uuid()) @db.Uuid
  userId                     String                @db.Uuid
  user                       User                  @relation(fields: [userId], references: [id])
  userNameSnapshot           String
  roleSnapshot               String
  operationalDate            DateTime              @db.Date
  checkinAt                  DateTime?
  checkinLatitude            Decimal?              @db.Decimal(10, 7)
  checkinLongitude           Decimal?              @db.Decimal(10, 7)
  checkinDistanceMeter       Decimal?              @db.Decimal(10, 2)
  checkinStatus              AttendancePointStatus?
  checkoutAt                 DateTime?
  checkoutLatitude           Decimal?              @db.Decimal(10, 7)
  checkoutLongitude          Decimal?              @db.Decimal(10, 7)
  checkoutDistanceMeter      Decimal?              @db.Decimal(10, 2)
  checkoutStatus             AttendancePointStatus?
  qrTokenIdCheckin           String?               @db.Uuid
  qrTokenCheckin             AttendanceQrToken?    @relation("CheckinQrToken", fields: [qrTokenIdCheckin], references: [id])
  qrTokenIdCheckout          String?               @db.Uuid
  qrTokenCheckout            AttendanceQrToken?    @relation("CheckoutQrToken", fields: [qrTokenIdCheckout], references: [id])
  deviceInfoCheckin          String?
  deviceInfoCheckout         String?
  ipAddressCheckin           String?
  ipAddressCheckout          String?
  status                     AttendanceRecordStatus
  notes                      String?
  createdAt                  DateTime              @default(now())
  createdBy                  String                @db.Uuid
  updatedAt                  DateTime              @updatedAt
  updatedBy                  String?               @db.Uuid

  corrections                AttendanceCorrection[]

  @@unique([userId, operationalDate])
  @@index([operationalDate])
}

model AttendanceCorrection {
  id                         String   @id @default(uuid()) @db.Uuid
  attendanceRecordId          String   @db.Uuid
  attendanceRecord            AttendanceRecord @relation(fields: [attendanceRecordId], references: [id])
  correctionType              String
  oldValue                    Json
  newValue                    Json
  reason                      String
  correctedBy                 String   @db.Uuid
  correctedByNameSnapshot     String
  correctedAt                 DateTime @default(now())
}

// ============================================================
// FINANCIAL ADJUSTMENTS
// ============================================================

model FinancialAdjustment {
  id                    String           @id @default(uuid()) @db.Uuid
  documentNo             String           @unique
  domain                 Domain
  adjustmentType         String
  ledgerAccount          String
  direction              Direction
  amount                 BigInt
  reason                 String
  sourceClosingId         String?          @db.Uuid
  status                 AdjustmentStatus  @default(selesai)
  reversalOfAdjustmentId String?           @db.Uuid
  reversedByAdjustmentId String?           @db.Uuid
  createdAt              DateTime         @default(now())
  createdBy              String           @db.Uuid

  @@index([domain])
  @@index([adjustmentType])
  @@index([createdAt])
}
