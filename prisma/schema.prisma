model BrilinkClosing {
  id                    String        @id @default(uuid())
  documentNo            String        @unique
  operationalDate       DateTime      @db.Date
  systemCashAmount      BigInt
  actualCashAmount      BigInt
  cashDifferenceAmount  BigInt
  systemSaldoAmount     BigInt
  actualSaldoAmount     BigInt
  saldoDifferenceAmount BigInt
  feeAmount             BigInt
  danaLuarAmount        BigInt
  injectionAmount       BigInt
  status                ClosingStatus @default(POSTED)
  note                  String?
  createdBy             String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([operationalDate, status])
  @@index([operationalDate])
