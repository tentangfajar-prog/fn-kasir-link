generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Domain {
  GLOBAL
  WARUNG
  BRILINK
}

model AuditLog {
  id        String   @id @default(uuid())
  domain    Domain
  action    String
  actorId   String?
  payload   Json?
  createdAt DateTime @default(now())
}
