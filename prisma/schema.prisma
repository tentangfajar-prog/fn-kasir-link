generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Domain {
  GLOBAL
  WARUNG
  BRILINK
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum PartnerType {
  SUPPLIER
  CONSIGNMENT
  BOTH
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum SettingScope {
  GLOBAL
  WARUNG
  BRILINK
  ABSENSI
  PRINT
  SYSTEM
}

enum SellableItemType {
  NORMAL
  RECIPE
  BUNDLE
}

enum PriceMode {
  MANUAL
  AUTO_HPP_PROFIT
}

enum StockMovementType {
  PURCHASE
  SALE
  COMPOSITION_SALE
  STOCK_OPNAME
  EXPIRED_RETURN
  REVERSAL
  ADJUSTMENT
}

enum StockDirection {
  IN
  OUT
}

enum StockOpnameStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum PaymentCategory {
  CASH
  NON_CASH
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum WarungCashAccount {
  KAS_LACI
  KAS_AMAN
}

enum WarungFinanceStatus {
  POSTED
  CANCELLED
}

enum PurchasePaymentStatus {
  PAID_CASH
  SUPPLIER_DEBT
}

enum SupplierDebtStatus {
  OPEN
  PARTIAL
  PAID
  CANCELLED
}

enum BrilinkAmountFormula {
  NONE
  NOMINAL
  FEE
  NOMINAL_PLUS_FEE
}

enum BrilinkTransactionStatus {
  COMPLETED
  CANCELLED
}

enum BrilinkFundAccount {
  CASH
  SALDO
}

enum BrilinkTemporaryFundStatus {
  ACTIVE
  PARTIAL
  RETURNED
  CANCELLED
}

enum AttendanceRecordStatus {
  CHECKED_IN
  CHECKED_OUT
  CORRECTED
  CANCELLED
}

enum ClosingStatus {
  POSTED
  CANCELLED
}

enum ConsignmentStatus {
  ACTIVE
  SETTLED
  RETURNED
  CANCELLED
}

model User {
  id                 String                   @id @default(uuid())
  name               String
  username           String                   @unique
  phone              String?
  email              String?                  @unique
  passwordHash       String
  status             UserStatus               @default(ACTIVE)
  mustChangePassword Boolean                  @default(false)
  roleId             String
  role               Role                     @relation(fields: [roleId], references: [id])
  permissionOverrides UserPermissionOverride[]
  loginHistories     LoginHistory[]
  deviceHistories    DeviceHistory[]
  auditLogs          AuditLog[]               @relation("AuditActor")
  attendanceRecords  AttendanceRecord[]
  apiSessions        ApiSession[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(true)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String                   @id @default(uuid())
  code        String                   @unique
  name        String
  domain      Domain
  module      String
  description String?
  sensitive   Boolean                  @default(false)
  roleLinks   RolePermission[]
  overrides   UserPermissionOverride[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([domain, module])
  @@index([sensitive])
}

model RolePermission {
  id           String       @id @default(uuid())
  roleId       String
  permissionId String
  effect       PermissionEffect @default(ALLOW)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String           @id @default(uuid())
  userId       String
  permissionId String
  effect       PermissionEffect
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String?
  username  String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([username])
  @@index([createdAt])
}

model DeviceHistory {
  id        String   @id @default(uuid())
  userId    String
  fingerprint String
  ipAddress String?
  userAgent String?
  lastSeenAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([lastSeenAt])
}

model Partner {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  address     String?
  notes       String?
  partnerType PartnerType
  status      PartnerStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([partnerType, status])
  @@index([name])
}

model Setting {
  id        String       @id @default(uuid())
  scope     SettingScope
  key       String
  value     Json
  sensitive Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([scope, key])
  @@index([scope])
}

model DocumentSequence {
  id        String   @id @default(uuid())
  domain    Domain
  code      String
  prefix    String
  currentNo Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, code])
}

model Attachment {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
}

model PrintLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  entityNo   String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
  @@index([actorId])
}

model WarungUnit {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  isDecimalAllowed Boolean  @default(false)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  stockProducts    WarungStockProduct[]
  conversionsFrom  WarungProductUnitConversion[] @relation("ConversionFromUnit")
  conversionsTo    WarungProductUnitConversion[] @relation("ConversionToUnit")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
}

model WarungProductCategory {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  sellableItems WarungSellableItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model WarungStockProduct {
  id               String   @id @default(uuid())
  name             String
  baseUnitId       String
  baseUnit         WarungUnit @relation(fields: [baseUnitId], references: [id])
  sku              String?  @unique
  barcode          String?  @unique
  minStockQty      Decimal  @default(0) @db.Decimal(18, 3)
  currentStockQty  Decimal  @default(0) @db.Decimal(18, 3)
  currentHppAmount BigInt   @default(0)
  isActive         Boolean  @default(true)
  notes            String?
  sellableItems    WarungSellableItem[]
  conversions      WarungProductUnitConversion[]
  componentOf      WarungItemComposition[]
  stockMovements   WarungStockMovement[]
  saleItems        WarungSaleItem[]
  opnameItems      WarungStockOpnameItem[]
  purchaseItems    WarungPurchaseItem[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([name])
  @@index([isActive])
}

model WarungProductUnitConversion {
  id             String   @id @default(uuid())
  stockProductId String
  stockProduct   WarungStockProduct @relation(fields: [stockProductId], references: [id])
  fromUnitId     String
  fromUnit       WarungUnit @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnitId       String
  toUnit         WarungUnit @relation("ConversionToUnit", fields: [toUnitId], references: [id])
  conversionQty  Decimal  @db.Decimal(18, 6)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([stockProductId])
  @@index([fromUnitId, toUnitId])
}

model WarungSellableItem {
  id                 String           @id @default(uuid())
  itemType           SellableItemType @default(NORMAL)
  stockProductId     String?
  stockProduct       WarungStockProduct? @relation(fields: [stockProductId], references: [id])
  categoryId         String
  category           WarungProductCategory @relation(fields: [categoryId], references: [id])
  name               String
  sku                String? @unique
  barcode            String? @unique
  sellingPriceAmount BigInt
  priceMode          PriceMode @default(MANUAL)
  targetProfitAmount BigInt?
  isFavorite         Boolean @default(false)
  isActive           Boolean @default(true)
  sortOrder          Int     @default(0)
  notes              String?
  compositions       WarungItemComposition[]
  saleItems          WarungSaleItem[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([name])
  @@index([categoryId])
  @@index([isActive])
}

model WarungItemComposition {
  id                 String   @id @default(uuid())
  sellableItemId     String
  sellableItem       WarungSellableItem @relation(fields: [sellableItemId], references: [id], onDelete: Cascade)
  componentProductId String
  componentProduct   WarungStockProduct @relation(fields: [componentProductId], references: [id])
  qtyBase            Decimal  @db.Decimal(18, 3)
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([sellableItemId])
  @@index([componentProductId])
}

model WarungStockMovement {
  id                String            @id @default(uuid())
  stockProductId    String
  stockProduct      WarungStockProduct @relation(fields: [stockProductId], references: [id])
  movementType      StockMovementType
  direction         StockDirection
  qtyBase           Decimal           @db.Decimal(18, 3)
  hppAmountSnapshot BigInt?
  valueAmount       BigInt?
  sourceType        String
  sourceId          String
  documentNo        String
  operationalDate   DateTime          @db.Date
  createdBy         String
  createdAt         DateTime          @default(now())

  @@index([stockProductId])
  @@index([movementType])
  @@index([operationalDate])
  @@index([sourceType, sourceId])
}

model WarungStockOpname {
  id              String              @id @default(uuid())
  documentNo      String              @unique
  operationalDate DateTime            @db.Date
  status          StockOpnameStatus   @default(DRAFT)
  notes           String?
  postedAt        DateTime?
  postedBy        String?
  items           WarungStockOpnameItem[]
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operationalDate])
  @@index([status])
}

model WarungStockOpnameItem {
  id             String   @id @default(uuid())
  opnameId       String
  opname         WarungStockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  stockProductId String
  stockProduct   WarungStockProduct @relation(fields: [stockProductId], references: [id])
  systemQtyBase  Decimal  @db.Decimal(18, 3)
  physicalQtyBase Decimal @db.Decimal(18, 3)
  differenceQtyBase Decimal @db.Decimal(18, 3)
  notes          String?
  createdAt      DateTime @default(now())

  @@unique([opnameId, stockProductId])
  @@index([stockProductId])
}

model WarungPaymentMethod {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique
  category  PaymentCategory
  isActive  Boolean         @default(true)
  sortOrder Int             @default(0)
  sales     WarungSale[]
  ledgers   WarungNonCashLedger[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
}

model WarungSale {
  id                        String          @id @default(uuid())
  documentNo                String          @unique
  operationalDate           DateTime        @db.Date
  cashierUserId             String
  cashierNameSnapshot       String
  cashierRoleSnapshot       String
  paymentMethodId           String
  paymentMethod             WarungPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  paymentMethodNameSnapshot String
  paymentCategorySnapshot   PaymentCategory
  subtotalAmount            BigInt
  totalDiscountAmount       BigInt          @default(0)
  totalAmount               BigInt
  cashReceivedAmount        BigInt?
  changeAmount              BigInt?
  status                    SaleStatus      @default(COMPLETED)
  items                     WarungSaleItem[]
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  @@index([operationalDate])
  @@index([cashierUserId])
  @@index([status])
}

model WarungSaleItem {
  id                       String           @id @default(uuid())
  saleId                   String
  sale                     WarungSale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sellableItemId           String
  sellableItem             WarungSellableItem @relation(fields: [sellableItemId], references: [id])
  stockProductId           String?
  stockProduct             WarungStockProduct? @relation(fields: [stockProductId], references: [id])
  sellableItemNameSnapshot String
  itemTypeSnapshot         SellableItemType
  categoryNameSnapshot     String
  qty                      Decimal          @db.Decimal(18, 3)
  qtyBase                  Decimal?         @db.Decimal(18, 3)
  sellingPriceSnapshot     BigInt
  hppSnapshotAmount        BigInt?
  grossAmount              BigInt
  discountAmount           BigInt           @default(0)
  netAmount                BigInt
  profitAmount             BigInt
  compositionSnapshot      Json?
  createdAt                DateTime         @default(now())

  @@index([saleId])
  @@index([sellableItemId])
  @@index([stockProductId])
}


model WarungPurchase {
  id                    String                @id @default(uuid())
  documentNo            String                @unique
  operationalDate       DateTime              @db.Date
  partnerId             String
  partnerNameSnapshot   String
  paymentStatus         PurchasePaymentStatus
  cashSource            WarungCashAccount?
  subtotalAmount        BigInt
  invoiceDiscountAmount BigInt                @default(0)
  totalAmount           BigInt
  status                WarungFinanceStatus   @default(POSTED)
  note                  String?
  createdBy             String
  items                 WarungPurchaseItem[]
  supplierDebt          WarungSupplierDebt?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([operationalDate])
  @@index([partnerId])
  @@index([paymentStatus])
  @@index([status])
}

model WarungPurchaseItem {
  id                       String             @id @default(uuid())
  purchaseId               String
  purchase                 WarungPurchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stockProductId           String
  stockProduct             WarungStockProduct @relation(fields: [stockProductId], references: [id])
  stockProductNameSnapshot String
  qtyBase                  Decimal            @db.Decimal(18, 3)
  unitPriceAmount          BigInt
  discountAmount           BigInt             @default(0)
  invoiceDiscountShare     BigInt             @default(0)
  netAmount                BigInt
  hppAmount                BigInt
  createdAt                DateTime           @default(now())

  @@index([purchaseId])
  @@index([stockProductId])
}

model WarungSupplierDebt {
  id                  String                         @id @default(uuid())
  purchaseId          String                         @unique
  purchase            WarungPurchase                 @relation(fields: [purchaseId], references: [id])
  documentNo          String                         @unique
  partnerId           String
  partnerNameSnapshot String
  principalAmount     BigInt
  paidAmount          BigInt                         @default(0)
  remainingAmount     BigInt
  status              SupplierDebtStatus             @default(OPEN)
  payments            WarungSupplierDebtPayment[]
  createdBy           String
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  @@index([partnerId])
  @@index([status])
}

model WarungSupplierDebtPayment {
  id              String             @id @default(uuid())
  debtId          String
  debt            WarungSupplierDebt @relation(fields: [debtId], references: [id])
  documentNo      String             @unique
  operationalDate DateTime           @db.Date
  cashSource      WarungCashAccount
  amount          BigInt
  status          WarungFinanceStatus @default(POSTED)
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([debtId])
  @@index([operationalDate])
  @@index([status])
}

model WarungExpenseCategory {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique
  isActive  Boolean         @default(true)
  sortOrder Int             @default(0)
  expenses  WarungExpense[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?
}

model WarungExpense {
  id                   String                @id @default(uuid())
  documentNo           String                @unique
  operationalDate      DateTime              @db.Date
  account              WarungCashAccount
  categoryId           String
  category             WarungExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryNameSnapshot String
  description          String
  amount               BigInt
  status               WarungFinanceStatus   @default(POSTED)
  note                 String?
  createdBy            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([operationalDate])
  @@index([account])
  @@index([categoryId])
  @@index([status])
}

model WarungCashTransfer {
  id              String              @id @default(uuid())
  documentNo      String              @unique
  operationalDate DateTime            @db.Date
  fromAccount     WarungCashAccount
  toAccount       WarungCashAccount
  amount          BigInt
  status          WarungFinanceStatus @default(POSTED)
  note            String?
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operationalDate])
  @@index([fromAccount, toAccount])
  @@index([status])
}

model WarungCashLedger {
  id              String            @id @default(uuid())
  account         WarungCashAccount
  direction       StockDirection
  amount          BigInt
  sourceType      String
  sourceId        String
  documentNo      String
  operationalDate DateTime          @db.Date
  note            String?
  createdBy       String
  createdAt       DateTime          @default(now())

  @@index([account])
  @@index([sourceType, sourceId])
  @@index([operationalDate])
}

model WarungNonCashLedger {
  id              String   @id @default(uuid())
  paymentMethodId String
  paymentMethod   WarungPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  direction       StockDirection
  amount          BigInt
  sourceType      String
  sourceId        String
  documentNo      String
  operationalDate DateTime @db.Date
  note            String?
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([paymentMethodId])
  @@index([sourceType, sourceId])
  @@index([operationalDate])
}


model BrilinkCashSaldoTemplate {
  id                String               @id @default(uuid())
  code              String               @unique
  name              String
  cashDirection     StockDirection?
  cashAmountFormula BrilinkAmountFormula @default(NONE)
  saldoDirection    StockDirection?
  saldoAmountFormula BrilinkAmountFormula @default(NONE)
  isActive          Boolean              @default(true)
  transactionTypes  BrilinkTransactionType[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([isActive])
}

model BrilinkTransactionType {
  id           String                    @id @default(uuid())
  code         String                    @unique
  name         String
  templateId   String
  template     BrilinkCashSaldoTemplate  @relation(fields: [templateId], references: [id])
  isActive     Boolean                   @default(true)
  sortOrder    Int                       @default(0)
  tariffGroups BrilinkTariffGroup[]
  transactions BrilinkTransaction[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  deletedAt    DateTime?

  @@index([templateId])
  @@index([isActive])
}

model BrilinkTariffGroup {
  id                  String                 @id @default(uuid())
  transactionTypeId   String
  transactionType     BrilinkTransactionType @relation(fields: [transactionTypeId], references: [id])
  name                String
  bankCategory        String?
  isActive            Boolean                @default(true)
  ranges              BrilinkTariffRange[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([transactionTypeId, bankCategory])
  @@index([isActive])
}

model BrilinkTariffRange {
  id            String             @id @default(uuid())
  tariffGroupId String
  tariffGroup   BrilinkTariffGroup @relation(fields: [tariffGroupId], references: [id])
  minAmount     BigInt
  maxAmount     BigInt?
  feeAmount     BigInt
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tariffGroupId])
  @@index([minAmount, maxAmount])
  @@index([isActive])
}

model BrilinkTransaction {
  id                          String                   @id @default(uuid())
  documentNo                  String                   @unique
  operationalDate             DateTime                 @db.Date
  transactionTypeId           String
  transactionType             BrilinkTransactionType   @relation(fields: [transactionTypeId], references: [id])
  transactionTypeNameSnapshot String
  templateCodeSnapshot        String
  bankCategory                String?
  nominalAmount               BigInt
  feeAmount                   BigInt
  cashInAmount                BigInt                   @default(0)
  cashOutAmount               BigInt                   @default(0)
  saldoInAmount               BigInt                   @default(0)
  saldoOutAmount              BigInt                   @default(0)
  referenceNo                 String?
  targetAccountNo             String?
  targetPhoneNo               String?
  targetName                  String?
  providerName                String?
  customerName                String?
  status                      BrilinkTransactionStatus @default(COMPLETED)
  note                        String?
  createdBy                   String
  cashLedgers                 BrilinkCashLedger[]
  saldoLedgers                BrilinkSaldoLedger[]
  feeLedgers                  BrilinkFeeLedger[]
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  @@index([operationalDate])
  @@index([transactionTypeId])
  @@index([status])
  @@index([createdBy])
}

model BrilinkCashLedger {
  id              String             @id @default(uuid())
  transactionId   String?
  transaction     BrilinkTransaction? @relation(fields: [transactionId], references: [id])
  direction       StockDirection
  amount          BigInt
  sourceType      String
  sourceId        String
  documentNo      String
  operationalDate DateTime           @db.Date
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())

  @@index([transactionId])
  @@index([sourceType, sourceId])
  @@index([operationalDate])
}

model BrilinkSaldoLedger {
  id              String             @id @default(uuid())
  transactionId   String?
  transaction     BrilinkTransaction? @relation(fields: [transactionId], references: [id])
  direction       StockDirection
  amount          BigInt
  sourceType      String
  sourceId        String
  documentNo      String
  operationalDate DateTime           @db.Date
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())

  @@index([transactionId])
  @@index([sourceType, sourceId])
  @@index([operationalDate])
}

model BrilinkFeeLedger {
  id              String             @id @default(uuid())
  transactionId   String?
  transaction     BrilinkTransaction? @relation(fields: [transactionId], references: [id])
  direction       StockDirection
  amount          BigInt
  sourceType      String
  sourceId        String
  documentNo      String
  operationalDate DateTime           @db.Date
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())

  @@index([transactionId])
  @@index([sourceType, sourceId])
  @@index([operationalDate])
}


model BrilinkDanaLuar {
  id              String                      @id @default(uuid())
  documentNo      String                      @unique
  operationalDate DateTime                    @db.Date
  borrowerName    String
  sourceAccount   BrilinkFundAccount
  principalAmount BigInt
  returnedAmount  BigInt                      @default(0)
  remainingAmount BigInt
  status          BrilinkTemporaryFundStatus  @default(ACTIVE)
  note            String?
  createdBy       String
  returns         BrilinkDanaLuarReturn[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  @@index([operationalDate])
  @@index([sourceAccount])
  @@index([status])
}

model BrilinkDanaLuarReturn {
  id              String             @id @default(uuid())
  danaLuarId      String
  danaLuar        BrilinkDanaLuar    @relation(fields: [danaLuarId], references: [id])
  documentNo      String             @unique
  operationalDate DateTime           @db.Date
  returnToAccount BrilinkFundAccount
  amount          BigInt
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([danaLuarId])
  @@index([operationalDate])
}

model BrilinkInjection {
  id                String                      @id @default(uuid())
  documentNo        String                      @unique
  operationalDate   DateTime                    @db.Date
  fundProviderName  String
  targetAccount     BrilinkFundAccount
  principalAmount   BigInt
  returnedAmount    BigInt                      @default(0)
  remainingAmount   BigInt
  status            BrilinkTemporaryFundStatus  @default(ACTIVE)
  note              String?
  createdBy         String
  returns           BrilinkInjectionReturn[]
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([operationalDate])
  @@index([targetAccount])
  @@index([status])
}

model BrilinkInjectionReturn {
  id              String             @id @default(uuid())
  injectionId     String
  injection       BrilinkInjection   @relation(fields: [injectionId], references: [id])
  documentNo      String             @unique
  operationalDate DateTime           @db.Date
  returnFromAccount BrilinkFundAccount
  amount          BigInt
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([injectionId])
  @@index([operationalDate])
}




