model ConsignmentEntry {
  id                  String              @id @default(uuid())
  domain              Domain
  documentNo          String              @unique
  operationalDate     DateTime            @db.Date
  partnerId           String
  partnerNameSnapshot String
  itemName            String
  qtyReceived         Decimal             @db.Decimal(18, 3)
  qtySold             Decimal             @default(0) @db.Decimal(18, 3)
  qtyReturned         Decimal             @default(0) @db.Decimal(18, 3)
  qtyPaid             Decimal             @default(0) @db.Decimal(18, 3)
  unitCostAmount      BigInt
  status              ConsignmentStatus   @default(ACTIVE)
  note                String?
  createdBy           String
  payments            ConsignmentPayment[]
  returns             ConsignmentReturn[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([domain])
  @@index([partnerId])
  @@index([status])
}

model ConsignmentPayment {
  id              String             @id @default(uuid())
  entryId         String
  entry           ConsignmentEntry   @relation(fields: [entryId], references: [id])
  documentNo      String             @unique
  operationalDate DateTime           @db.Date
  qtyPaid         Decimal            @db.Decimal(18, 3)
  amount          BigInt
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())

  @@index([entryId])
  @@index([operationalDate])
}

model ConsignmentReturn {
  id              String             @id @default(uuid())
  entryId         String
  entry           ConsignmentEntry   @relation(fields: [entryId], references: [id])
  documentNo      String             @unique
  operationalDate DateTime           @db.Date
  qtyReturned     Decimal            @db.Decimal(18, 3)
  note            String?
  createdBy       String
  createdAt       DateTime           @default(now())

  @@index([entryId])
  @@index([operationalDate])
}

model ReversalRecord {
  id              String   @id @default(uuid())
  documentNo      String   @unique
  domain          Domain
  sourceType      String
  sourceId        String
  reason          String
  createdBy       String
  createdAt       DateTime @default(now())

  @@unique([domain, sourceType, sourceId])
  @@index([domain])
  @@index([sourceType, sourceId])
}

model ApiSession {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AttendanceSetting {
  id              String    @id @default(uuid())
  name            String
  latitude        Decimal   @db.Decimal(10, 7)
  longitude       Decimal   @db.Decimal(10, 7)
  radiusMeters    Int       @default(100)
  qrTtlSeconds    Int       @default(60)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([isActive])
}

model AttendanceQrToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

model AttendanceRecord {
  id                String                  @id @default(uuid())
  userId            String
  user              User                    @relation(fields: [userId], references: [id])
  attendanceDate    DateTime                @db.Date
  checkInAt         DateTime?
  checkInLatitude   Decimal?                @db.Decimal(10, 7)
  checkInLongitude  Decimal?                @db.Decimal(10, 7)
  checkInDistanceM  Int?
  checkOutAt        DateTime?
  checkOutLatitude  Decimal?                @db.Decimal(10, 7)
  checkOutLongitude Decimal?                @db.Decimal(10, 7)
  checkOutDistanceM Int?
  status            AttendanceRecordStatus  @default(CHECKED_IN)
  corrections       AttendanceCorrection[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([userId, attendanceDate])
  @@index([attendanceDate])
  @@index([status])
}

model AttendanceCorrection {
  id          String           @id @default(uuid())
  recordId    String
  record      AttendanceRecord @relation(fields: [recordId], references: [id])
  reason      String
  oldValue    Json
  newValue    Json
  correctedBy String
  createdAt   DateTime         @default(now())

  @@index([recordId])
  @@index([correctedBy])
}

model AuditLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  action     String
  entityType String?
  entityId   String?
  entityNo   String?
  actorId    String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
