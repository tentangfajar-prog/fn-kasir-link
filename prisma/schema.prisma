generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Domain {
  GLOBAL
  WARUNG
  BRILINK
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum PartnerType {
  SUPPLIER
  CONSIGNMENT
  BOTH
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum SettingScope {
  GLOBAL
  WARUNG
  BRILINK
  ABSENSI
  PRINT
  SYSTEM
}

enum SellableItemType {
  NORMAL
  RECIPE
  BUNDLE
}

enum PriceMode {
  MANUAL
  AUTO_HPP_PROFIT
}

enum StockMovementType {
  PURCHASE
  SALE
  COMPOSITION_SALE
  STOCK_OPNAME
  EXPIRED_RETURN
  REVERSAL
  ADJUSTMENT
}

enum StockDirection {
  IN
  OUT
}

enum StockOpnameStatus {
  DRAFT
  POSTED
  CANCELLED
}

model User {
  id                 String                   @id @default(uuid())
  name               String
  username           String                   @unique
  phone              String?
  email              String?                  @unique
  passwordHash       String
  status             UserStatus               @default(ACTIVE)
  mustChangePassword Boolean                  @default(false)
  roleId             String
  role               Role                     @relation(fields: [roleId], references: [id])
  permissionOverrides UserPermissionOverride[]
  loginHistories     LoginHistory[]
  deviceHistories    DeviceHistory[]
  auditLogs          AuditLog[]               @relation("AuditActor")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(true)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String                   @id @default(uuid())
  code        String                   @unique
  name        String
  domain      Domain
  module      String
  description String?
  sensitive   Boolean                  @default(false)
  roleLinks   RolePermission[]
  overrides   UserPermissionOverride[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([domain, module])
  @@index([sensitive])
}

model RolePermission {
  id           String       @id @default(uuid())
  roleId       String
  permissionId String
  effect       PermissionEffect @default(ALLOW)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String           @id @default(uuid())
  userId       String
  permissionId String
  effect       PermissionEffect
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String?
  username  String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([username])
  @@index([createdAt])
}

model DeviceHistory {
  id        String   @id @default(uuid())
  userId    String
  fingerprint String
  ipAddress String?
  userAgent String?
  lastSeenAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([lastSeenAt])
}

model Partner {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  address     String?
  notes       String?
  partnerType PartnerType
  status      PartnerStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([partnerType, status])
  @@index([name])
}

model Setting {
  id        String       @id @default(uuid())
  scope     SettingScope
  key       String
  value     Json
  sensitive Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([scope, key])
  @@index([scope])
}

model DocumentSequence {
  id        String   @id @default(uuid())
  domain    Domain
  code      String
  prefix    String
  currentNo Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, code])
}

model Attachment {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
}

model PrintLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  entityNo   String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
  @@index([actorId])
}

model WarungUnit {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  isDecimalAllowed Boolean  @default(false)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  stockProducts    WarungStockProduct[]
  conversionsFrom  WarungProductUnitConversion[] @relation("ConversionFromUnit")
  conversionsTo    WarungProductUnitConversion[] @relation("ConversionToUnit")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
}

model WarungProductCategory {
  id            String   @id @default(uuid())
  name          String
  code          String   @unique
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  sellableItems WarungSellableItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model WarungStockProduct {
  id               String   @id @default(uuid())
  name             String
  baseUnitId       String
  baseUnit         WarungUnit @relation(fields: [baseUnitId], references: [id])
  sku              String?  @unique
  barcode          String?  @unique
  minStockQty      Decimal  @default(0) @db.Decimal(18, 3)
  currentStockQty  Decimal  @default(0) @db.Decimal(18, 3)
  currentHppAmount BigInt   @default(0)
  isActive         Boolean  @default(true)
  notes            String?
  sellableItems    WarungSellableItem[]
  conversions      WarungProductUnitConversion[]
  componentOf      WarungItemComposition[]
  stockMovements   WarungStockMovement[]
  opnameItems      WarungStockOpnameItem[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([name])
  @@index([isActive])
}

model WarungProductUnitConversion {
  id             String   @id @default(uuid())
  stockProductId String
  stockProduct   WarungStockProduct @relation(fields: [stockProductId], references: [id])
  fromUnitId     String
  fromUnit       WarungUnit @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnitId       String
  toUnit         WarungUnit @relation("ConversionToUnit", fields: [toUnitId], references: [id])
  conversionQty  Decimal  @db.Decimal(18, 6)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([stockProductId])
  @@index([fromUnitId, toUnitId])
}

model WarungSellableItem {
  id                 String           @id @default(uuid())
  itemType           SellableItemType @default(NORMAL)
  stockProductId     String?
  stockProduct       WarungStockProduct? @relation(fields: [stockProductId], references: [id])
  categoryId         String
  category           WarungProductCategory @relation(fields: [categoryId], references: [id])
  name               String
  sku                String? @unique
  barcode            String? @unique
  sellingPriceAmount BigInt
  priceMode          PriceMode @default(MANUAL)
  targetProfitAmount BigInt?
  isFavorite         Boolean @default(false)
  isActive           Boolean @default(true)
  sortOrder          Int     @default(0)
  notes              String?
  compositions       WarungItemComposition[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([name])
  @@index([categoryId])
  @@index([isActive])
}

model WarungItemComposition {
  id                 String   @id @default(uuid())
  sellableItemId     String
  sellableItem       WarungSellableItem @relation(fields: [sellableItemId], references: [id], onDelete: Cascade)
  componentProductId String
  componentProduct   WarungStockProduct @relation(fields: [componentProductId], references: [id])
  qtyBase            Decimal  @db.Decimal(18, 3)
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([sellableItemId])
  @@index([componentProductId])
}

model WarungStockMovement {
  id                String            @id @default(uuid())
  stockProductId    String
  stockProduct      WarungStockProduct @relation(fields: [stockProductId], references: [id])
  movementType      StockMovementType
  direction         StockDirection
  qtyBase           Decimal           @db.Decimal(18, 3)
  hppAmountSnapshot BigInt?
  valueAmount       BigInt?
  sourceType        String
  sourceId          String
  documentNo        String
  operationalDate   DateTime          @db.Date
  createdBy         String
  createdAt         DateTime          @default(now())

  @@index([stockProductId])
  @@index([movementType])
  @@index([operationalDate])
  @@index([sourceType, sourceId])
}

model WarungStockOpname {
  id              String              @id @default(uuid())
  documentNo      String              @unique
  operationalDate DateTime            @db.Date
  status          StockOpnameStatus   @default(DRAFT)
  notes           String?
  postedAt        DateTime?
  postedBy        String?
  items           WarungStockOpnameItem[]
  createdBy       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operationalDate])
  @@index([status])
}

model WarungStockOpnameItem {
  id             String   @id @default(uuid())
  opnameId       String
  opname         WarungStockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  stockProductId String
  stockProduct   WarungStockProduct @relation(fields: [stockProductId], references: [id])
  systemQtyBase  Decimal  @db.Decimal(18, 3)
  physicalQtyBase Decimal @db.Decimal(18, 3)
  differenceQtyBase Decimal @db.Decimal(18, 3)
  notes          String?
  createdAt      DateTime @default(now())

  @@unique([opnameId, stockProductId])
  @@index([stockProductId])
}

model AuditLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  action     String
  entityType String?
  entityId   String?
  entityNo   String?
  actorId    String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
