generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Domain {
  GLOBAL
  WARUNG
  BRILINK
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum PartnerType {
  SUPPLIER
  CONSIGNMENT
  BOTH
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum SettingScope {
  GLOBAL
  WARUNG
  BRILINK
  ABSENSI
  PRINT
  SYSTEM
}

model User {
  id                 String                   @id @default(uuid())
  name               String
  username           String                   @unique
  phone              String?
  email              String?                  @unique
  passwordHash       String
  status             UserStatus               @default(ACTIVE)
  mustChangePassword Boolean                  @default(false)
  roleId             String
  role               Role                     @relation(fields: [roleId], references: [id])
  permissionOverrides UserPermissionOverride[]
  loginHistories     LoginHistory[]
  deviceHistories    DeviceHistory[]
  auditLogs          AuditLog[]               @relation("AuditActor")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(true)
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String                   @id @default(uuid())
  code        String                   @unique
  name        String
  domain      Domain
  module      String
  description String?
  sensitive   Boolean                  @default(false)
  roleLinks   RolePermission[]
  overrides   UserPermissionOverride[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([domain, module])
  @@index([sensitive])
}

model RolePermission {
  id           String       @id @default(uuid())
  roleId       String
  permissionId String
  effect       PermissionEffect @default(ALLOW)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String           @id @default(uuid())
  userId       String
  permissionId String
  effect       PermissionEffect
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String?
  username  String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([username])
  @@index([createdAt])
}

model DeviceHistory {
  id        String   @id @default(uuid())
  userId    String
  fingerprint String
  ipAddress String?
  userAgent String?
  lastSeenAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([lastSeenAt])
}

model Partner {
  id          String        @id @default(uuid())
  name        String
  phone       String?
  address     String?
  notes       String?
  partnerType PartnerType
  status      PartnerStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([partnerType, status])
  @@index([name])
}

model Setting {
  id        String       @id @default(uuid())
  scope     SettingScope
  key       String
  value     Json
  sensitive Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([scope, key])
  @@index([scope])
}

model DocumentSequence {
  id        String   @id @default(uuid())
  domain    Domain
  code      String
  prefix    String
  currentNo Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([domain, code])
}

model Attachment {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
}

model PrintLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  entityType String
  entityId   String
  entityNo   String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([entityType, entityId])
  @@index([actorId])
}

model AuditLog {
  id         String   @id @default(uuid())
  domain     Domain
  module     String
  action     String
  entityType String?
  entityId   String?
  entityNo   String?
  actorId    String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([domain, module])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
